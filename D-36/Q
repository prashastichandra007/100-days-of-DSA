Problem: Circular Queue Using Array - Implement using linked list with dynamic memory allocation.
solution - #include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    int data;
    struct Node* next;
};

struct Node *front = NULL, *rear = NULL;

// Enqueue
void enqueue(int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;

    // If queue is empty
    if (front == NULL) {
        front = rear = newNode;
        rear->next = front; // circular link
    } else {
        rear->next = newNode;
        rear = newNode;
        rear->next = front; // maintain circular nature
    }

    printf("✅ %d inserted\n", value);
}

// Dequeue
void dequeue() {
    if (front == NULL) {
        printf("❌ Queue Underflow\n");
        return;
    }

    // Only one node
    if (front == rear) {
        printf("🗑️ %d removed\n", front->data);
        free(front);
        front = rear = NULL;
    } else {
        struct Node* temp = front;
        printf("🗑️ %d removed\n", front->data);
        front = front->next;
        rear->next = front; // maintain circular link
        free(temp);
    }
}

// Display
void display() {
    if (front == NULL) {
        printf("⚠️ Queue is empty\n");
        return;
    }

    struct Node* temp = front;
    printf("📚 Circular Queue: ");

    do {
        printf("%d -> ", temp->data);
        temp = temp->next;
    } while (temp != front);

    printf("(back to front)\n");
}

// Main
int main() {
    enqueue(10);
    enqueue(20);
    enqueue(30);

    display();

    dequeue();
    display();

    dequeue();
    dequeue();
    dequeue(); // underflow check

    return 0;
}
