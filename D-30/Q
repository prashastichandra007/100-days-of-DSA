Problem: Polynomial Using Linked List - Implement using linked list with dynamic memory allocation.
Solution:- #include <stdio.h>
#include <stdlib.h>

// Structure for polynomial node
struct Node {
    int coeff;
    int exp;
    struct Node* next;
};

// Create new node
struct Node* createNode(int c, int e) {
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->coeff = c;
    temp->exp = e;
    temp->next = NULL;
    return temp;
}

// Insert node at end
void insert(struct Node** head, int c, int e) {
    struct Node* temp = createNode(c, e);

    if (*head == NULL) {
        *head = temp;
        return;
    }

    struct Node* ptr = *head;
    while (ptr->next != NULL)
        ptr = ptr->next;

    ptr->next = temp;
}

// Display polynomial
void display(struct Node* head) {
    while (head != NULL) {
        printf("%dx^%d", head->coeff, head->exp);
        if (head->next != NULL)
            printf(" + ");
        head = head->next;
    }
    printf("\n");
}

// Add two polynomials
struct Node* addPoly(struct Node* p1, struct Node* p2) {
    struct Node* result = NULL;

    while (p1 && p2) {
        if (p1->exp == p2->exp) {
            insert(&result, p1->coeff + p2->coeff, p1->exp);
            p1 = p1->next;
            p2 = p2->next;
        }
        else if (p1->exp > p2->exp) {
            insert(&result, p1->coeff, p1->exp);
            p1 = p1->next;
        }
        else {
            insert(&result, p2->coeff, p2->exp);
            p2 = p2->next;
        }
    }

    while (p1) {
        insert(&result, p1->coeff, p1->exp);
        p1 = p1->next;
    }

    while (p2) {
        insert(&result, p2->coeff, p2->exp);
        p2 = p2->next;
    }

    return result;
}

// Main function
int main() {
    struct Node *poly1 = NULL, *poly2 = NULL, *result = NULL;

    // Polynomial 1: 5x^2 + 4x + 2
    insert(&poly1, 5, 2);
    insert(&poly1, 4, 1);
    insert(&poly1, 2, 0);

    // Polynomial 2: 3x^2 + 2x + 1
    insert(&poly2, 3, 2);
    insert(&poly2, 2, 1);
    insert(&poly2, 1, 0);

    printf("Polynomial 1: ");
    display(poly1);

    printf("Polynomial 2: ");
    display(poly2);

    result = addPoly(poly1, poly2);

    printf("Resultant Polynomial: ");
    display(result);

    return 0;
}
